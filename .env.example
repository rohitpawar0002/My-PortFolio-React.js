# Optional (Vite dev only): default proxy target is rohitt-portfolio-react.netlify.app in vite.config.js.
# Override if you need a different deployed function:
# VITE_CHAT_PROXY=https://YOUR_SITE.netlify.app
#
# Netlify (Site → Environment variables), not Vite: GEMINI_API_KEY is required for chat.
# Use a key from https://aistudio.google.com/ (free tier, rate-limited) — do not enable paid Cloud
# billing for this key if you want to stay on $0. Recheck https://ai.google.dev/pricing when needed.
# Optional: GEMINI_MODEL=gemini-2.5-flash  (must be Flash / Flash-Lite style; see netlify/functions/chat.js)
#
# Restart Vite after changing. No variable is required for production (same-origin on Netlify).
